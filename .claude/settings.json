{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/changelog-guard.sh\"",
            "timeout": 10,
            "statusMessage": "Checking version-bump / changelog guard"
          }
        ]
      }
    ]
  }
}
